using System;
using System.Collections.Generic;
using Propulsion;
using Power;
using Structure;
using SensorNamespace;
using UModelLib;
using UModelLibrary;
using Data;
using CAD;
using Controls;
using SystemsEngineering;
using DreamWorldMakerLibrary;

namespace SysML
{
    public class UModelApp : ApplicationClass
    {
        //  *****************************************************************************************
        //  DECLARATIONS
        //
        //  ************************************************************
        //
        //  Identification
        private String _Name;

        //
        //  Owned & Owning Objects
        //  
        //  My UModel Application Object
        private UModelLib.Application _CurrentApplication;
        //
        //  Current UModel Document
        private UModelDocument _CurrentDocument;
        

        //  *****************************************************************************************


        //  ****************************************************************************************
        //  INITIALIZATIONS
        //
        //  ************************************************************

        //  *****************************************************************************************


        //  *****************************************************************************************
        //  ENUMERATIONS
        //
        //  ************************************************************

        //  *****************************************************************************************


        //  *****************************************************************************************
        //  UMODELAPP CONSTRUCTOR
        //
        //  ************************************************************
        public UModelApp(UModelLib.Application MyUModelApp)
        {
            CurrentApplication = MyUModelApp;

            IDiagramWindow activeDiagram = MyUModelApp.ActiveDocument.ActiveDiagramWindow;
            IUMLGuiSysMLBlockDefinitionDiagram sysMlBddInterface =
                (IUMLGuiSysMLBlockDefinitionDiagram)activeDiagram.Diagram;
        }

        //  *****************************************************************************************


        //  *****************************************************************************************
        //  PROPERTIES
        //
        //  ************************************************************
        //
        //  Identification
        //
        //  Name
        public string Name
        {
            get
            {
                return "UModel";
            }
        }

        //
        //  Owned & Owning Objects
        //
        //  My UModel Application Object
        public UModelLib.Application? CurrentApplication { get; set; }

        //
        //  Documents
        //
        //  Current UModel Document
        public UModelDocument? CurrentDocument { get; set; }

        //  **************
        //  *****************************************************************************************


        //  *****************************************************************************************
        //  METHODS
        //
        //  ************************************************************
        //  ************************************************************
        //  CREATE A UMODEL DOCUMENT AND MAKE IT CURRENT
        #region
        public bool CreateUModelApp()
        {
            try
            {
                CurrentApplication = new UModelLib.Application
                {
                    Visible = true
                };

                return true;
            }

            catch
            {
                return false;
            }
        }
        #endregion
        //  *****************************************************************************************


        //  *****************************************************************************************
        //  EVENTS
        //
        //  ************************************************************

        //  *****************************************************************************************
    }
}